# =============================================================
# Variables del COMPOSE MAESTRO (Essenz Master Orchestrator)
# Copia este archivo como .env (está en .gitignore) y rellena.
#
# Se inyectan como build-args a los frontends (portal e InShop),
# que las hornean en su bundle con Vite. La anon key de Supabase
# es pública por diseño, así que es seguro hornearla.
# =============================================================

# --- Supabase (compartido por portal e InShop) ---------------
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# --- Dominio del ecosistema ----------------------------------
# A dónde apuntan los canales del Hub. En desarrollo, al gateway
# local (mismo origen -> sesión Supabase compartida con InShop).
# En producción: https://essenz.cl
VITE_ESSENZ_DOMINIO=http://localhost:8080
